            "console": "integratedTerminal",
            "args": [
                "--dataset",
                "chase",
                "--data_root",
                "data/chase",
                "--resize",
                "960",
                "960",
                "--num-class",
                "1",
                "--batch-size",
                "4",
                "--epochs",
                "130",
                "--lr",
                "0.0038",
                "--lr-update",
                "poly",
                "--folds",
                "5",
                "--label_mode",
                "dist",
            ]
        }
